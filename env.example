# Porta do servidor
PORT=3000

# (Opcional) Google Sheets
# 1) Compartilhe a planilha com a service account (Editor)
# 2) Preencha o ID da planilha (parte /d/<ID>/edit)
GOOGLE_SHEETS_SPREADSHEET_ID=

# Aba/range onde será feito append (padrão: Leads!A:Z)
GOOGLE_SHEETS_RANGE=Leads!A:Z

# Caminho para o JSON da Service Account (recomendado)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# Alternativa ao PATH: JSON completo em uma linha
GOOGLE_SERVICE_ACCOUNT_JSON=
